PORT=5600
# Optional: persistent data directory (e.g. /data on Render with a disk mounted).
# When set, SQLite DB and uploads live here so they survive deploys.
# DATA_DIR=/data
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GEMINI_API_KEY=

# GitHub: for Seed users push and Index/Board push from president (optional).
# Create a token at https://github.com/settings/tokens with repo scope.
GITHUB_TOKEN=
GITHUB_REPO=https://github.com/currentlycrafting/ssa-umn-edu
# Default branch (e.g. main or dev)
GITHUB_BRANCH=dev
